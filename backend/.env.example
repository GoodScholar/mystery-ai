# 服务
PORT=3000
NODE_ENV=development

# 数据库
MONGODB_URI=mongodb://localhost:27017/mijuai
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here

# AI API（服务端托管）
AI_API_KEY=sk-xxxxxx
AI_API_BASE=https://api.deepseek.com/v1
AI_API_MODEL=deepseek-chat

# AI API 备用
AI_API_KEY_BACKUP=
AI_API_BASE_BACKUP=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_MODEL_BACKUP=gemini-2.0-flash

# 前端域名白名单
CORS_ORIGINS=http://localhost:5173,https://mijuai.example.com
